# ─── Server ──────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Security ────────────────────────────────────────────────────────
JWT_SECRET=super-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ─── PostgreSQL ──────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cyberlearn

# ─── Initial Admin ──────────────────────────────────────────────────
ADMIN_EMAIL=admin@cyberlearn.io
ADMIN_PASSWORD=Admin1234!
